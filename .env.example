# Пример файла .env - скопируйте и переименуйте в .env

# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=False

# Database
DB_NAME=argus_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Email (Gmail)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Site URL
SITE_URL=https://your-domain.ru

# CSRF Trusted Origins
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://your-domain.ru